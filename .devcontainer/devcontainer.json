{
  "name": "jedi-spatial-audio",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "postCreateCommand": "git clone https://github.com/microsoft/vcpkg.git /workspaces/vcpkg || true && /workspaces/vcpkg/bootstrap-vcpkg.sh",
  "containerEnv": {
    "VCPKG_ROOT": "/workspaces/vcpkg"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools"
      ]
    }
  }
}
